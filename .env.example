# ============================================
# DATABASE (PostgreSQL di host VPS)
# ============================================
DATABASE_URL="postgresql://easylegal:your_password_here@host.docker.internal:5432/easylegal?schema=public"
DIRECT_URL="postgresql://easylegal:your_password_here@host.docker.internal:5432/easylegal?schema=public"

# ============================================
# JWT AUTH
# ============================================
JWT_SECRET="generate-with-openssl-rand-base64-32"

# ============================================
# EMAIL (Hostinger SMTP)
# ============================================
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT=465
SMTP_USER="newsletter@easylegal.id"
SMTP_PASS="your_email_password"
SMTP_FROM='"Easy Legal" <newsletter@easylegal.id>'

# ============================================
# APP URL
# ============================================
NEXT_PUBLIC_APP_URL="https://easylegal.id"
