# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# SSL certs (generated on VPS)
nginx/certs/

# vercel
.vercel

# Uploads and 2FA QR codes (local only, keep folder structure via .gitkeep)
public/uploads/*
!public/uploads/**/.gitkeep

# scripts (ignore local stress test scripts and any custom scripts)
scripts/stress-test.js

# typescript
*.tsbuildinfo
next-env.d.ts

# IDEs and editors
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace

# OS and system files
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs and temp files
*.log
logs/
.eslintcache


# Sentry Config File
.env.sentry-build-plugin

# Testing outputs and reports
dogfood-output/
playwright-report/
playwright/.cache/
test-results/

# AI tool generated files
CLAUDE.md
PLANNING.md
DAILY-PLAN.md

# AI agents/skills (local environment, not project code)
.agents/
.claude/skills/
skills-lock.json
docs/superpowers/

# Stray binaries in public
public/logo-berita/*.msi

# Document files
*.docx
COPYWRITING_AUDIT.md
*.csv
docs/mobile-responsive-optimization.md
docs/typebot-improvements.md
docs/architecture-optimization.md
today-worked-*.md
weekly-report-*.md
easylegal_links.csv
graphify-out/

# Accidental uploads
Telegram Desktop/
